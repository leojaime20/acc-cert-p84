{
  "name": "acc-cert",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "npx --yes firebase-tools@15.24.0 emulators:exec --project acc-cert-photo-rules-test --only firestore,storage \"tsx tests/storage.rules.ts\"",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "seed:p84": "tsx scripts/seed-p84.ts",
    "seed:p84:dry-run": "tsx scripts/seed-p84.ts --dry-run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "browser-image-compression": "^2.0.2",
    "firebase": "^12.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^14.2.0",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.0"
  }
}
